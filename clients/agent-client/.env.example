# Agent Client 独立端口，注意不要和 FreeChat Server(3001)/Web(5173) 冲突
AGENT_CLIENT_HOST=127.0.0.1
AGENT_CLIENT_PORT=5188
AGENT_CLIENT_PUBLIC_URL=https://agent-client.example.com

# 公网访问必须配置管理员密码；默认 127.0.0.1 本地访问可不配
AGENT_CLIENT_ADMIN_PASSWORD=change-me

# 只连接一个 FreeChat 中心服务器；一个客户端可管理多个 Agent 登录
FREECHAT_SERVER_URL=http://localhost:3001
AGENT_CLIENT_HOME=~/.freechat-agent-client
AGENT_CLIENT_NAME=my-agent-client
AGENT_CLIENT_MAX_CONCURRENCY=2
FREECHAT_POLL_INTERVAL_MS=3000
FREECHAT_CLAUDE_MODEL=
